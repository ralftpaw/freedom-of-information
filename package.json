{
  "name": "freedom-of-information",
  "version": "0.1.0",
  "description": "Infrastructure for resilient internet communication under authoritarian control",
  "license": "MIT",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "ci": "npm run build && npm run test && npm run lint"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
